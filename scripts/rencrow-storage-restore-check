#!/usr/bin/env bash
set -Eeuo pipefail
umask 077

snapshot_dir=${1:-}
if [[ -z ${snapshot_dir} || ! -d ${snapshot_dir} ]]; then
  echo "usage: rencrow-storage-restore-check SNAPSHOT_DIR" >&2
  exit 2
fi

archive=${snapshot_dir}/rencrow-state.tar.gz
manifest=${snapshot_dir}/manifest.txt
checksums=${snapshot_dir}/SHA256SUMS
for required in "${archive}" "${manifest}" "${checksums}"; do
  if [[ ! -f ${required} ]]; then
    echo "[NG] required snapshot file is missing: ${required}" >&2
    exit 1
  fi
done

manifest_value() {
  local key=$1
  awk -F= -v key="${key}" '$1 == key {sub(/^[^=]*=/, ""); print; exit}' "${manifest}"
}

format_version=$(manifest_value format_version)
core_name=$(manifest_value core_name)
session_relative=$(manifest_value session_relative)
operation_memory_relative=$(manifest_value operation_memory_relative)
cold_export_relative=$(manifest_value cold_export_relative)
conversation_l1_relative=$(manifest_value conversation_l1_relative)
conversation_archive_relative=$(manifest_value conversation_archive_relative)
redis_export=$(manifest_value redis_export)
qdrant_export=$(manifest_value qdrant_export)
qdrant_sha256=$(manifest_value qdrant_sha256)

if [[ ( ${format_version} != 2 && ${format_version} != 3 ) || -z ${core_name} || ${core_name} == */* ]]; then
  echo "[NG] unsupported or unsafe snapshot manifest" >&2
  exit 1
fi

(
  cd "${snapshot_dir}"
  sha256sum -c SHA256SUMS
)
gzip -t "${archive}"

tar -tzf "${archive}" | python3 -c '
import sys
for raw in sys.stdin:
    name = raw.strip()
    parts = [part for part in name.split("/") if part not in ("", ".")]
    if name.startswith("/") or ".." in parts:
        raise SystemExit("unsafe archive path: " + name)
'

restore_root=$(mktemp -d)
cleanup() {
  local status=$?
  trap - EXIT INT TERM
  if [[ -n ${restore_root:-} && -d ${restore_root} ]]; then
    rm -rf -- "${restore_root}"
  fi
  exit "${status}"
}
trap cleanup EXIT INT TERM

tar -xzf "${archive}" -C "${restore_root}"
core_restore=${restore_root}/${core_name}

for relative in "${session_relative}" "${operation_memory_relative}" "${cold_export_relative}"; do
  if [[ -z ${relative} || ${relative} == /* || ${relative} == *../* || ${relative} == .. ]]; then
    echo "[NG] unsafe required directory in manifest: ${relative}" >&2
    exit 1
  fi
  if [[ ! -d ${core_restore}/${relative} ]]; then
    echo "[NG] required memory directory is missing from snapshot: ${relative}" >&2
    exit 1
  fi
done

python3 - "${core_restore}/${conversation_l1_relative}" "${core_restore}/${conversation_archive_relative}" <<'PY'
import sqlite3
import sys

for path in sys.argv[1:]:
    if not path or "/../" in path:
        raise SystemExit("unsafe SQLite path")
    with open(path, "rb") as handle:
        if handle.read(16) != b"SQLite format 3\x00":
            raise SystemExit(f"not a SQLite database: {path}")
    connection = sqlite3.connect(f"file:{path}?mode=ro", uri=True)
    try:
        result = connection.execute("PRAGMA integrity_check").fetchone()
    finally:
        connection.close()
    if not result or result[0] != "ok":
        raise SystemExit(f"SQLite integrity check failed: {path}: {result}")
PY

if [[ ${redis_export} != disabled ]]; then
  redis_path=${restore_root}/${redis_export}
  if [[ ! -s ${redis_path} || $(head -c 5 "${redis_path}") != REDIS ]]; then
    echo "[NG] Redis RDB is missing or invalid" >&2
    exit 1
  fi
fi
if [[ ${qdrant_export} != disabled ]]; then
  qdrant_path=${restore_root}/${qdrant_export}
  if [[ ! -s ${qdrant_path} ]]; then
    echo "[NG] Qdrant snapshot is missing or empty" >&2
    exit 1
  fi
  if [[ ${format_version} == 3 ]]; then
    if [[ ! ${qdrant_sha256} =~ ^[0-9a-f]{64}$ ]]; then
      echo "[NG] Qdrant snapshot checksum metadata is invalid" >&2
      exit 1
    fi
    printf '%s  %s\n' "${qdrant_sha256}" "${qdrant_path}" | sha256sum -c -
  fi
fi

echo "[OK] snapshot is checksum-valid, extractable, and restorable: ${snapshot_dir}"
