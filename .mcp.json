{
  "mcpServers": {
    "serena": {
      "command": "/home/nyukimi/.local/bin/uvx",
      "env": {
        "GOCACHE": "/home/nyukimi/picoclaw_multiLLM/.serena/go-build",
        "GOMODCACHE": "/home/nyukimi/picoclaw_multiLLM/.serena/gomodcache",
        "SERENA_HOME": "/home/nyukimi/picoclaw_multiLLM/.serena",
        "UV_OFFLINE": "1",
        "UV_CACHE_DIR": "/home/nyukimi/picoclaw_multiLLM/.serena/uv-cache",
        "UV_TOOL_DIR": "/home/nyukimi/picoclaw_multiLLM/.serena/uv-tools",
        "XDG_CACHE_HOME": "/home/nyukimi/picoclaw_multiLLM/.serena/xdg-cache"
      },
      "args": [
        "--from",
        "/home/nyukimi/serena",
        "serena-mcp-server",
        "--enable-web-dashboard",
        "False",
        "--project-from-cwd"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "aidesigner": {
      "type": "http",
      "url": "https://api.aidesigner.ai/api/v1/mcp"
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    }
  }
}
