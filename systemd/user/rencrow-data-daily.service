[Unit]
Description=RenCrow data daily ingest
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
Environment=RENCROW_REPO_DIR=@RENCROW_REPO_DIR@
ExecStart=/usr/bin/env bash -lc 'exec "%h/.local/share/rencrow/scripts/rencrow_data_scheduler.sh" daily'
WorkingDirectory=%h
StandardOutput=append:%h/.rencrow/logs/rencrow-data-daily.log
StandardError=append:%h/.rencrow/logs/rencrow-data-daily.log

[Install]
WantedBy=default.target
