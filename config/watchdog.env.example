# Viewer Tailscale Serve watchdog baseline (copy selected values to ~/.picoclaw/.env)

PICOCLAW_WATCHDOG_INTERVAL_SEC=60

# Local RenCrow runtime.
PICOCLAW_WATCHDOG_RENCROW_URL=http://127.0.0.1:18790
PICOCLAW_WATCHDOG_HEALTH_URL=http://127.0.0.1:18790/health

# Tailnet-only Viewer endpoint.
PICOCLAW_WATCHDOG_TAILSCALE_HOST=fujitsu-ubunts.tailb07d8d.ts.net
PICOCLAW_WATCHDOG_VIEWER_URL=https://fujitsu-ubunts.tailb07d8d.ts.net/viewer?tab=timeline
PICOCLAW_WATCHDOG_SERVE_TARGET=http://127.0.0.1:18790

# Timeouts.
PICOCLAW_WATCHDOG_LOCAL_TIMEOUT_SEC=3
PICOCLAW_WATCHDOG_EXTERNAL_TIMEOUT_SEC=8

# This watchdog intentionally does not manage:
# - Tailscale Funnel
# - LINE webhook ports
# - LLM/Ollama servers
# - gateway restarts
