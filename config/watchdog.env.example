# Viewer Tailscale Serve watchdog baseline (copy selected values to ~/.rencrow/.env)

RENCROW_WATCHDOG_INTERVAL_SEC=60

# Local RenCrow runtime.
RENCROW_WATCHDOG_RENCROW_URL=http://127.0.0.1:18790
RENCROW_WATCHDOG_HEALTH_URL=http://127.0.0.1:18790/health

# Tailnet-only Viewer endpoint.
RENCROW_WATCHDOG_TAILSCALE_HOST=fujitsu-ubunts.tailb07d8d.ts.net
RENCROW_WATCHDOG_VIEWER_URL=https://fujitsu-ubunts.tailb07d8d.ts.net/viewer?tab=timeline
RENCROW_WATCHDOG_SERVE_TARGET=http://127.0.0.1:18790

# Timeouts.
RENCROW_WATCHDOG_LOCAL_TIMEOUT_SEC=3
RENCROW_WATCHDOG_EXTERNAL_TIMEOUT_SEC=8

# This watchdog intentionally does not manage:
# - Tailscale Funnel
# - LINE webhook ports
# - LLM/Ollama servers
# - gateway restarts
